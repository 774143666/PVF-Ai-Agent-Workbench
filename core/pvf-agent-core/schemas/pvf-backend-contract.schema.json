{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pvf-backend-contract.schema.json",
  "title": "PVF Backend Contract",
  "type": "object",
  "required": ["schemaVersion", "contractId", "requiredCapabilities", "safetyInvariants", "defaultFixture"],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "contractId": { "type": "string", "minLength": 1 },
    "phase": { "type": "string" },
    "backendRole": { "type": "string" },
    "defaultFixture": { "type": "string", "minLength": 1 },
    "reportSchema": { "type": "string" },
    "requiredCapabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "level", "summary"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "level": { "type": "string", "minLength": 1 },
          "summary": { "type": "string", "minLength": 1 },
          "requiredTools": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "artifacts": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "mustNot": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        },
        "additionalProperties": true
      }
    },
    "safetyInvariants": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "additionalProperties": true
}
