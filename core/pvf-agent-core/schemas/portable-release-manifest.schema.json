{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "portable-release-manifest.schema.json",
  "title": "PVF Agent Workbench Portable Release Manifest",
  "type": "object",
  "required": ["schemaVersion", "phase", "packageName", "packageVersion", "portableCore", "exclude", "validation", "safety"],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "phase": { "const": "agent-workspace-portable-release" },
    "packageName": { "type": "string", "minLength": 1 },
    "packageVersion": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "portableCore": {
      "type": "object",
      "required": ["include"],
      "properties": {
        "include": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
      }
    },
    "exclude": { "type": "object" },
    "validation": { "type": "object" },
    "safety": { "type": "object" }
  },
  "additionalProperties": true
}
