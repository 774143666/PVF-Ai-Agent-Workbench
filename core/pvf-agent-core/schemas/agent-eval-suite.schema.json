{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agent-eval-suite.schema.json",
  "type": "object",
  "required": ["schemaVersion", "suiteId", "version", "minimumAverageScore", "cases"],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "suiteId": { "type": "string" },
    "version": { "type": "string" },
    "minimumAverageScore": { "type": "number", "minimum": 0, "maximum": 1 },
    "cases": { "type": "array", "minItems": 1 }
  }
}
