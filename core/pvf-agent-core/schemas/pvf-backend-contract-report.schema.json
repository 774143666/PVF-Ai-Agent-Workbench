{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pvf-backend-contract-report.schema.json",
  "title": "PVF Backend Contract Report",
  "type": "object",
  "required": ["schemaVersion", "phase", "generatedAt", "contractId", "summary", "tests"],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "phase": { "type": "string" },
    "generatedAt": { "type": "string" },
    "contractId": { "type": "string" },
    "profile": { "type": ["string", "null"] },
    "sourcePvf": { "type": "string" },
    "fixtureId": { "type": "string" },
    "reportPath": { "type": "string" },
    "summary": {
      "type": "object",
      "required": ["ok", "passed", "failed", "skipped"],
      "properties": {
        "ok": { "type": "boolean" },
        "passed": { "type": "integer", "minimum": 0 },
        "failed": { "type": "integer", "minimum": 0 },
        "skipped": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    },
    "tests": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "ok"],
        "properties": {
          "id": { "type": "string" },
          "ok": { "type": "boolean" },
          "skipped": { "type": "boolean" },
          "details": {},
          "error": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
